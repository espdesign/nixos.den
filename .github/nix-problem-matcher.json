{
  "problemMatcher": [
    {
      "owner": "nix-evaluation-warning",
      "pattern": [
        {
          "regexp": "^(?:trace: )?evaluation warning: (.*)$",
          "message": 1
        }
      ]
    },
    {
      "owner": "nix-unknown-flake-output",
      "severity": "notice",
      "pattern": [
        {
          "regexp": "^warning: unknown flake output '.*'$",
          "message": 0
        }
      ]
    },
    {
      "owner": "nix-warning",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^warning: (.*)$",
          "message": 1
        }
      ]
    }
  ]
}
